# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
.DS_Store

vendor
.vscode
.idea
dist/
main

# Renderer-version stamp for docs/diagrams/out/%.png (Makefile) — forces
# re-render when PLANTUML_VERSION bumps; not a rendered artifact itself.
docs/diagrams/out/.plantuml-*.stamp
# Stray per-service compiled binaries (canonical build uses `-o main`, ignored above)
dapr-go-read-values
dapr-go-write-values
dapr-go-subscriber
dapr-go-frontendsvc
